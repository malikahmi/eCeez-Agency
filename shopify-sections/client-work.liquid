{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .client-work-wrapper {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    max-width: 120rem;
    margin: 0 auto;
    padding: 0 2rem;
  }

  @media screen and (min-width: 990px) {
    .client-work-wrapper {
      flex-direction: row;
      align-items: center;
    }
  }

  .client-list {
    flex: 1;
  }

  .client-item {
    border-bottom: 1px solid rgba(0,0,0,0.05);
    padding: 2rem 0;
    cursor: pointer;
    transition: all 0.4s ease;
    position: relative;
  }

  .client-item:hover .client-name {
    transform: translateY(-5px);
    color: {{ section.settings.accent_color }};
  }

  .client-name {
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 700;
    margin: 0;
    transition: all 0.4s ease;
    color: rgba(0,0,0,0.3);
  }

  .client-item.active .client-name {
    color: #000;
  }

  .client-category {
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 1rem;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .client-item.active .client-category {
    opacity: 0.6;
  }

  .client-image-display {
    flex: 1;
    position: relative;
    aspect-ratio: 4/5;
    border-radius: 2rem;
    overflow: hidden;
    background: #f5f5f5;
  }

  .client-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.6s ease, transform 0.6s ease;
    transform: scale(1.05);
  }

  .client-image.active {
    opacity: 1;
    transform: scale(1);
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding" style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};">
  <div class="client-work-wrapper">
    <div class="client-list">
      {%- if section.settings.heading != blank -%}
        <h2 class="h1">{{ section.settings.heading }}</h2>
      {%- endif -%}
      
      <div class="client-items-container">
        {%- for block in section.blocks -%}
          <div class="client-item {% if forloop.first %}active{% endif %}" 
               data-client-id="{{ block.id }}"
               {{ block.shopify_attributes }}>
            <h3 class="client-name">{{ block.settings.client_name }}</h3>
            <p class="client-category">{{ block.settings.category }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="client-image-display">
      {%- for block in section.blocks -%}
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 1000 | image_tag: 
            class: 'client-image', 
            data-client-image-id: block.id,
            loading: 'lazy'
          }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'client-image' }}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const items = document.querySelectorAll('.client-item');
    const images = document.querySelectorAll('.client-image');

    function setActive(id) {
      items.forEach(item => {
        item.classList.toggle('active', item.dataset.clientId === id);
      });
      images.forEach(img => {
        img.classList.toggle('active', img.dataset.clientImageId === id);
      });
    }

    items.forEach(item => {
      item.addEventListener('mouseenter', () => {
        setActive(item.dataset.clientId);
      });
    });
  });
</script>

{% schema %}
{
  "name": "Client Work Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Client Work"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "client",
      "name": "Client Project",
      "settings": [
        {
          "type": "text",
          "id": "client_name",
          "label": "Client Name",
          "default": "Project Name"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category",
          "default": "E-commerce Design"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Project Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Client Work Section",
      "blocks": [
        { "type": "client" },
        { "type": "client" },
        { "type": "client" }
      ]
    }
  ]
}
{% endschema %}
